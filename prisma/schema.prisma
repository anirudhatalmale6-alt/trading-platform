generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String      @id @default(cuid())
  email         String      @unique
  passwordHash  String
  name          String?
  phone         String?
  angelApiKey   String?
  angelClientId String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  watchlists    Watchlist[]
  orders        Order[]
  holdings      Holding[]
  positions     Position[]
}

model Watchlist {
  id        String   @id @default(cuid())
  userId    String
  symbol    String
  exchange  String   @default("NSE")
  name      String?
  token     String?
  addedAt   DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol, exchange])
}

model Order {
  id            String   @id @default(cuid())
  userId        String
  symbol        String
  exchange      String   @default("NSE")
  side          String   // BUY | SELL
  orderType     String   // MARKET | LIMIT | SL | SL_M
  productType   String   @default("DELIVERY") // DELIVERY | INTRADAY
  quantity      Int
  price         Decimal?
  triggerPrice  Decimal?
  status        String   @default("PENDING") // PENDING | OPEN | COMPLETE | CANCELLED | REJECTED
  brokerOrderId String?
  filledQty     Int      @default(0)
  avgFillPrice  Decimal?
  placedAt      DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Holding {
  id          String   @id @default(cuid())
  userId      String
  symbol      String
  exchange    String   @default("NSE")
  name        String?
  quantity    Int
  avgPrice    Decimal
  investedVal Decimal?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol, exchange])
}

model Position {
  id          String   @id @default(cuid())
  userId      String
  symbol      String
  exchange    String   @default("NSE")
  name        String?
  quantity    Int
  avgPrice    Decimal
  side        String   // BUY | SELL
  dayPnl      Decimal  @default(0)
  productType String   @default("INTRADAY")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol, exchange])
}
