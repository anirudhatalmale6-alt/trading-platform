generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model TradingUser {
  id            String            @id @default(cuid())
  email         String            @unique
  passwordHash  String
  name          String?
  phone         String?
  angelApiKey   String?
  angelClientId String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  watchlists    TradingWatchlist[]
  orders        TradingOrder[]
  holdings      TradingHolding[]
  positions     TradingPosition[]

  @@map("trading_users")
}

model TradingWatchlist {
  id        String      @id @default(cuid())
  userId    String
  symbol    String
  exchange  String      @default("NSE")
  name      String?
  token     String?
  addedAt   DateTime    @default(now())
  user      TradingUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol, exchange])
  @@map("trading_watchlists")
}

model TradingOrder {
  id            String      @id @default(cuid())
  userId        String
  symbol        String
  exchange      String      @default("NSE")
  side          String
  orderType     String
  productType   String      @default("DELIVERY")
  quantity      Int
  price         Decimal?
  triggerPrice  Decimal?
  status        String      @default("PENDING")
  brokerOrderId String?
  filledQty     Int         @default(0)
  avgFillPrice  Decimal?
  placedAt      DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  user          TradingUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("trading_orders")
}

model TradingHolding {
  id          String      @id @default(cuid())
  userId      String
  symbol      String
  exchange    String      @default("NSE")
  name        String?
  quantity    Int
  avgPrice    Decimal
  investedVal Decimal?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  user        TradingUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol, exchange])
  @@map("trading_holdings")
}

model TradingPosition {
  id          String      @id @default(cuid())
  userId      String
  symbol      String
  exchange    String      @default("NSE")
  name        String?
  quantity    Int
  avgPrice    Decimal
  side        String
  dayPnl      Decimal     @default(0)
  productType String      @default("INTRADAY")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  user        TradingUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol, exchange])
  @@map("trading_positions")
}
